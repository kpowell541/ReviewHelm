# ReviewHelm frontend environment template (Expo)
# Copy to .env.local (or your preferred local env file) for frontend development.

# --- API ---
EXPO_PUBLIC_API_BASE_URL=https://api-staging.reviewhelm.app
EXPO_PUBLIC_API_BASE_PATH=/api/v1

# --- Auth (Cognito) ---
EXPO_PUBLIC_COGNITO_REGION=us-east-1
EXPO_PUBLIC_COGNITO_USER_POOL_ID=
EXPO_PUBLIC_COGNITO_CLIENT_ID=
EXPO_PUBLIC_COGNITO_DOMAIN=
EXPO_PUBLIC_AUTH_REDIRECT_URI=
EXPO_PUBLIC_AUTH_LOGOUT_REDIRECT_URI=

# --- Web ---
EXPO_PUBLIC_WEB_ORIGIN=https://staging.reviewhelm.app
EXPO_PUBLIC_REGION_MODE=global
# Web auth persistence mode:
# - session (default): tab-scoped sessions, better token at-rest posture
# - local: persistent login across tabs/browser restarts
EXPO_PUBLIC_WEB_AUTH_STORAGE=session

# --- Staging access gate ---
# Set to "true" to hide signup and restrict login to admin/sponsored users
EXPO_PUBLIC_STAGING_ACCESS_GATE=false

# --- Observability ---
EXPO_PUBLIC_SENTRY_DSN=

# --- Checklist sync (optional overrides) ---
EXPO_PUBLIC_CHECKLIST_OWNER=kpowell541
EXPO_PUBLIC_CHECKLIST_REPO=ReviewHelm
EXPO_PUBLIC_CHECKLIST_BRANCH=main
