{
  "name": "reviewhelm",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "infisical run -- expo start",
    "android": "infisical run -- expo start --android",
    "ios": "infisical run -- expo start --ios",
    "web": "infisical run -- expo start --web",
    "build:web": "npx expo export --platform web",
    "build:web:staging": "npx expo export --platform web",
    "start:local": "expo start",
    "typecheck": "tsc --noEmit",
    "openapi:generate": "openapi-typescript docs/openapi.yaml -o src/api/generated.ts",
    "openapi:check": "openapi-typescript docs/openapi.yaml -o /dev/stdout | diff - src/api/generated.ts",
    "test": "jest --config jest.config.ts --runInBand",
    "test:unit": "jest --config jest.config.ts --runInBand",
    "test:integration": "jest --config jest.integration.config.ts --runInBand",
    "test:e2e": "npx playwright test",
    "test:ci": "jest --config jest.config.ts --runInBand --coverage"
  },
  "dependencies": {
    "@expo-google-fonts/quicksand": "^0.4.1",
    "@expo/metro-runtime": "~55.0.6",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@sentry/react": "^10.43.0",
    "@supabase/supabase-js": "^2.98.0",
    "@types/uuid": "^10.0.0",
    "amazon-cognito-identity-js": "^6.3.16",
    "expo": "~55.0.5",
    "expo-clipboard": "~55.0.8",
    "expo-constants": "~55.0.7",
    "expo-crypto": "~55.0.9",
    "expo-document-picker": "~55.0.8",
    "expo-file-system": "~55.0.10",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.8",
    "expo-linking": "~55.0.7",
    "expo-print": "~55.0.8",
    "expo-router": "~55.0.4",
    "expo-secure-store": "~55.0.8",
    "expo-sharing": "~55.0.11",
    "expo-status-bar": "~55.0.4",
    "punycode": "^2.3.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-markdown-display": "^7.0.2",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.2",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "openapi-typescript": "^7.13.0",
    "react-test-renderer": "^19.2.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
