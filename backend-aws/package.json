{
  "name": "reviewhelm-api-aws",
  "version": "0.1.0",
  "private": true,
  "description": "ReviewHelm AWS-native backend skeleton (Hono + Lambda)",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@aws-sdk/client-cost-explorer": "^3.1009.0",
    "@hono/node-server": "^1.14.1",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.44.5",
    "hono": "^4.7.2",
    "jose": "^6.1.3",
    "postgres": "^3.4.7",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "drizzle-kit": "^0.31.5",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  }
}
