# --------------------------------
# Runtime
# --------------------------------
NODE_ENV=development
PORT=3000
API_BASE_PATH=api/v1
API_PUBLIC_URL=http://localhost:3000
APP_VERSION=0.1.0
ENABLE_SWAGGER_DOCS=false
REQUEST_BODY_LIMIT=256kb
# Keep strict startup checks enabled in production unless doing emergency recovery.
STRICT_STARTUP_CHECKS=true

# --------------------------------
# Supabase (Auth + Postgres)
# --------------------------------
# Project URL from Supabase dashboard
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# JWT verification (prefer direct values from Supabase project settings)
SUPABASE_JWKS_URL=https://YOUR_PROJECT_REF.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_ISSUER=https://YOUR_PROJECT_REF.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated

# Optional service role key for privileged Supabase operations (never ship to client)
SUPABASE_SERVICE_ROLE_KEY=

# Prisma DB URLs (Supabase Postgres)
# Use pooler URL for runtime, direct URL for migrations.
DATABASE_URL=postgresql://postgres.YOUR_REF:YOUR_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres.YOUR_REF:YOUR_PASSWORD@db.YOUR_REF.supabase.co:5432/postgres

# --------------------------------
# Upstash Redis (cooldown/rate limiting/cache)
# --------------------------------
UPSTASH_REDIS_REST_URL=https://YOUR_INSTANCE.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace_me
RATE_LIMIT_PER_MINUTE=120
AI_RATE_LIMIT_PER_MINUTE=20
AI_COOLDOWN_SECONDS=6
HAIKU_INPUT_COST_PER_MILLION_USD=1
HAIKU_OUTPUT_COST_PER_MILLION_USD=5
SONNET_INPUT_COST_PER_MILLION_USD=3
SONNET_OUTPUT_COST_PER_MILLION_USD=15
OPUS_INPUT_COST_PER_MILLION_USD=15
OPUS_OUTPUT_COST_PER_MILLION_USD=75
RETAIN_DIFF_DAYS=90
RETAIN_CALIBRATION_DAYS=180
RETAIN_AUDIT_DAYS=365

# --------------------------------
# Vault-backed key encryption
# --------------------------------
# local: app-managed KEK in env (dev only)
# aws_kms: use AWS KMS GenerateDataKey/Decrypt with AWS_KMS_KEY_ID
KEY_ENCRYPTION_PROVIDER=local
KEY_ENCRYPTION_VERSION=1
KEY_ENCRYPTION_MASTER_KEY=<set-in-vault>
KEY_ENCRYPTION_MASTER_KEYS_JSON=
AWS_REGION=us-east-1
AWS_KMS_KEY_ID=
ADMIN_USER_IDS=
# Comma-separated email allow-list for admin dashboard access.
ADMIN_DASHBOARD_ALLOWED_EMAILS=kaitlin.e.powell@gmail.com
# GitHub workflow metadata for checklist relevance job visibility in admin dashboard.
CHECKLIST_RELEVANCE_WORKFLOW_OWNER=kpowell541
CHECKLIST_RELEVANCE_WORKFLOW_REPO=ReviewHelm
CHECKLIST_RELEVANCE_WORKFLOW_FILE=checklist-relevance-check.yml
GITHUB_READ_TOKEN=

# --------------------------------
# Stripe (payments)
# --------------------------------
# Use test keys (sk_test_...) for non-prod, live keys (sk_live_...) for production.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --------------------------------
# CORS
# --------------------------------
# Comma-separated allow-list for app origins and local tooling.
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006
