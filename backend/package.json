{
  "name": "reviewhelm-api",
  "version": "0.1.0",
  "private": true,
  "description": "ReviewHelm backend API (NestJS + Prisma + Supabase + Upstash)",
  "scripts": {
    "postinstall": "prisma generate",
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "infisical run -- nest start --watch",
    "start:debug": "infisical run -- nest start --debug --watch",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:ci": "jest --runInBand --coverage",
    "openapi:check-routes": "node scripts/check-openapi-routes.mjs",
    "openapi:validate": "node scripts/validate-openapi.mjs",
    "openapi:check-security": "node scripts/check-openapi-security.mjs",
    "checklists:sync": "node ../scripts/sync-backend-checklists.mjs",
    "checklists:verify-sync": "node ../scripts/check-backend-checklists-sync.mjs",
    "env:check": "node scripts/check-required-env.mjs",
    "smoke:health": "node scripts/smoke-health.mjs",
    "preflight": "node scripts/preflight.mjs",
    "prisma:generate": "infisical run -- prisma generate",
    "prisma:migrate:dev": "infisical run -- prisma migrate dev",
    "prisma:migrate:deploy": "infisical run -- prisma migrate deploy",
    "prisma:studio": "infisical run -- prisma studio"
  },
  "dependencies": {
    "@aws-sdk/client-kms": "^3.1002.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.0",
    "@prisma/client": "^6.19.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "jose": "^6.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "stripe": "^20.4.1",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@nestjs/cli": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.12.0",
    "@types/supertest": "^7.2.0",
    "jest": "^30.2.0",
    "js-yaml": "^4.1.1",
    "prisma": "^6.19.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  },
  "overrides": {
    "multer": "2.1.1"
  }
}
